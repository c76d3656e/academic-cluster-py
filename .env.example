# =============================================================================
# Academic Cluster Python - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Primary LLM Provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key_here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Secondary LLM Provider (for fallback or specialized tasks)
LLM_SECONDARY_PROVIDER=ollama
LLM_SECONDARY_MODEL=internlm3-8b-instruct
LLM_SECONDARY_BASE_URL=https://ai.gitee.com/v1
LLM_SECONDARY_API_KEY=your_secondary_api_key_here

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_DIMENSIONS=1024

# -----------------------------------------------------------------------------
# Rerank Configuration
# -----------------------------------------------------------------------------
RERANK_PROVIDER=siliconflow
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=your_rerank_api_key_here
RERANK_THRESHOLD=0.02

# -----------------------------------------------------------------------------
# Academic Data Sources
# -----------------------------------------------------------------------------
# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=your_s2_api_key_here
SEMANTIC_SCHOLAR_RATE_LIMIT=1

# PubMed
PUBMED_EMAIL=your_email@example.com
PUBMED_TOOL=AcademicReviewStudio
PUBMED_API_KEY=your_pubmed_api_key_here
PUBMED_RATE_LIMIT=10

# arXiv (no API key needed, but configure rate limits)
ARXIV_RATE_LIMIT=3
ARXIV_MAX_RESULTS=100

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=academic_cluster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# -----------------------------------------------------------------------------
# Vector Database
# -----------------------------------------------------------------------------
# Options: chromadb, pinecone, weaviate, qdrant
VECTOR_DB_PROVIDER=chromadb
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000
VECTOR_DB_API_KEY=your_vectordb_api_key_here

# -----------------------------------------------------------------------------
# LangGraph & LangSmith Configuration
# -----------------------------------------------------------------------------
LANGGRAPH_DEBUG=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=academic-cluster
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your_secret_key_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Clustering Configuration
# -----------------------------------------------------------------------------
CLUSTERING_ALGORITHM=leiden
CLUSTERING_RESOLUTION=1.0
CLUSTERING_MIN_CLUSTER_SIZE=5
CLUSTERING_MAX_CLUSTERS=50

# -----------------------------------------------------------------------------
# Writing Configuration
# -----------------------------------------------------------------------------
WRITING_MODEL=gpt-4o
WRITING_TEMPERATURE=0.7
WRITING_MAX_LENGTH=50000
OUTLINE_MAX_SECTIONS=10
OUTLINE_MAX_SUBSECTIONS=5

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60
