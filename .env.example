# =============================================================================
# Academic Cluster Python - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
# Primary LLM Provider（单 provider 时使用以下配置）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_api_key_here
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# LLM 多 Provider Pool（JSON 数组，设置后优先于上面的单 provider 配置）
# 支持：同 URL 多 key 负载均衡 + 不同 URL 不同 provider 混合
# LLM_PROVIDERS_JSON=[{"name":"gitee","model":"internlm3-8b-instruct","api_url":"https://ai.gitee.com/v1","api_key":"key1","rpm_limit":10,"priority":1},{"name":"siliconflow","model":"THUDM/GLM-Z1-9B-0414","api_url":"https://api.siliconflow.cn/v1","api_key":"key2","rpm_limit":30,"priority":1}]

# -----------------------------------------------------------------------------
# Embedding Configuration
# -----------------------------------------------------------------------------
# 单 Provider
EMBEDDING_PROVIDER=siliconflow
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_DIMENSIONS=1024

# 多 Provider Pool（JSON 数组，设置后优先于单 provider）
# EMBEDDING_PROVIDERS_JSON=[{"name":"siliconflow","model":"BAAI/bge-m3","api_url":"https://api.siliconflow.cn/v1","api_key":"key1","rpm_limit":10,"priority":1}]

# -----------------------------------------------------------------------------
# Rerank Configuration
# -----------------------------------------------------------------------------
# 单 Provider
RERANK_PROVIDER=siliconflow
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_URL=https://api.siliconflow.cn/v1
RERANK_API_KEY=your_rerank_api_key_here
RERANK_THRESHOLD=0.02

# 多 Provider Pool（JSON 数组，设置后优先于单 provider）
# RERANK_PROVIDERS_JSON=[{"name":"siliconflow","model":"BAAI/bge-reranker-v2-m3","api_url":"https://api.siliconflow.cn/v1","api_key":"key1","rpm_limit":10,"priority":1}]

# -----------------------------------------------------------------------------
# Academic Data Sources
# -----------------------------------------------------------------------------
# Semantic Scholar（多 key 逗号分隔，每个 key 独立 1 rps）
SEMANTIC_SCHOLAR_API_KEY=your_s2_key_1,your_s2_key_2
SEMANTIC_SCHOLAR_RATE_LIMIT=1

# PubMed
PUBMED_EMAIL=your_email@example.com
PUBMED_TOOL=AcademicReviewStudio
PUBMED_API_KEY=your_pubmed_api_key_here
PUBMED_RATE_LIMIT=10

# arXiv (no API key needed, but configure rate limits)
ARXIV_RATE_LIMIT=3
ARXIV_MAX_RESULTS=100

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=academic_cluster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# -----------------------------------------------------------------------------
# Vector Database
# -----------------------------------------------------------------------------
# Options: chromadb, pinecone, weaviate, qdrant
VECTOR_DB_PROVIDER=chromadb
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000
VECTOR_DB_API_KEY=your_vectordb_api_key_here

# -----------------------------------------------------------------------------
# LangGraph & LangSmith Configuration
# -----------------------------------------------------------------------------
LANGGRAPH_DEBUG=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=academic-cluster
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TRACING_V2=true

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your_secret_key_here

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# KG Extraction Configuration
# -----------------------------------------------------------------------------
# 每个 LLM 请求中包含的论文数量（1 = 每次只发1篇）
KG_BATCH_SIZE=1
# 并发请求数（根据 LLM provider 的 RPM 限制调整，如 100 RPM 设 10，300 RPM 设 30）
KG_CONCURRENCY=10

# -----------------------------------------------------------------------------
# Clustering Configuration
# -----------------------------------------------------------------------------
CLUSTERING_ALGORITHM=leiden
CLUSTERING_RESOLUTION=1.0
CLUSTERING_MIN_CLUSTER_SIZE=5
CLUSTERING_MAX_CLUSTERS=50

# -----------------------------------------------------------------------------
# Writing Configuration
# -----------------------------------------------------------------------------
WRITING_MODEL=gpt-4o
WRITING_TEMPERATURE=0.7
WRITING_MAX_LENGTH=50000
OUTLINE_MAX_SECTIONS=10
OUTLINE_MAX_SUBSECTIONS=5

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
GLOBAL_RATE_LIMIT=100
GLOBAL_RATE_LIMIT_WINDOW=60
